<?xml version="1.0"?>
<model>
  <name>oil_palm</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>User-provided asset</name>
  </author>
  <description>Oil palm (kelapa sawit) tree with trunk and fruit-cluster textures, provided by the user (originally authored in Blender, exported to FBX). Re-exported to OBJ+MTL via assimp so texture paths could be fixed from the original absolute Windows paths (D:\BLENDER\...) to paths relative to this model directory. Used by world_gen.py in place of a bare cylinder for the corridor's trunk placements.</description>
</model>

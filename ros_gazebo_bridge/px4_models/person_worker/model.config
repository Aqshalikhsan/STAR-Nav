<?xml version="1.0"?>
<model>
  <name>person_worker</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Standing human "worker" for STAR-Nav dynamic-object (CAMR) data. Mesh +
    textures are OpenRobotics' "Standing person" from Gazebo Fuel
    (https://fuel.gazebosim.org/1.0/OpenRobotics/models/Standing person),
    re-authored as a plain <![CDATA[<model>]]> (not a Fuel-linked <![CDATA[<actor>]]>) with a
    gz-sim Label plugin so the segmentation camera tags it CLASS_ACTOR (=4).
    Moved across the corridor at capture time via a VelocityControl plugin.
  </description>
</model>
